#--------------------------------------------------------------------
# CodeIgniter 4 Environment
#--------------------------------------------------------------------
CI_ENVIRONMENT = development

#--------------------------------------------------------------------
# APP
#--------------------------------------------------------------------
app.baseURL = 'http://localhost/dbdigitalagency/public/'
app.indexPage = ''
app.defaultLocale = 'fr'

APP_ENV = production
APP_DEBUG = false
APP_URL = 'https://dbdigitalagency.com'

#--------------------------------------------------------------------
# DATABASE
#--------------------------------------------------------------------
database.default.hostname = localhost
database.default.database = dbdigitalagency
database.default.username = root
database.default.password =
database.default.DBDriver = MySQLi
database.default.port = 3306

DB_HOST = localhost
DB_NAME = dbdigitalagency
DB_USER = root
DB_PASS =

#--------------------------------------------------------------------
# ENCRYPTION (generate with: php spark key:generate)
#--------------------------------------------------------------------
encryption.key =

#--------------------------------------------------------------------
# EMAIL
#--------------------------------------------------------------------
email.fromEmail = noreply@dbdigitalagency.com
email.fromName = 'DB Digital Agency'
email.protocol = smtp
email.SMTPHost = smtp.gmail.com
email.SMTPPort = 587
email.SMTPCrypto = tls

SMTP_HOST = smtp.gmail.com
SMTP_PORT = 587
SMTP_USERNAME =
SMTP_PASSWORD =
SMTP_ENCRYPTION = tls
SMTP_FROM_EMAIL = noreply@dbdigitalagency.com
SMTP_FROM_NAME = 'DB Digital Agency'
ADMIN_EMAIL = contact@dbdigitalagency.com

#--------------------------------------------------------------------
# SITE
#--------------------------------------------------------------------
CONTACT_ADDRESS = 'Douala, Yaounde, Bafoussam, Cameroon'
CONTACT_PHONE_1 = '+237 691 323 249'
CONTACT_PHONE_2 = '+237 658 910 343'
CONTACT_PHONE_3 = '+237 640 819 846'
CONTACT_EMAIL = contact@dbdigitalagency.com
WHATSAPP_NUMBER = 237691323249

SEO_INDEX = true
QUOTE_BRIEF_MAX_MB = 2
GOOGLE_MAPS_API_KEY =

#--------------------------------------------------------------------
# INTEGRATIONS (secret reCAPTCHA — site key dans Admin → Intégrations)
#--------------------------------------------------------------------
RECAPTCHA_SITE_KEY =
RECAPTCHA_SECRET_KEY =

# CDN optionnel pour assets statiques (ex. https://cdn.example.com)
# CDN_ASSETS_URL =

# Servir CSS/JS minifiés depuis assets/build/ (après php spark assets:build)
ASSETS_MINIFIED = false

#--------------------------------------------------------------------
# ADMIN SEED (php spark db:seed AdminUserSeeder)
#--------------------------------------------------------------------
ADMIN_SEED_EMAIL = admin@dbdigitalagency.com
